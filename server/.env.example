# Copy to .env.local for `vercel dev`. For production, set these as
# Project Environment Variables in the Vercel dashboard (or via
# `vercel env add`).

# OpenAI key — held server-side ONLY. Never prefix with anything that
# would expose it to the client.
OPENAI_API_KEY=sk-proj-replace-me

# Optional: extra comma-separated origins allowed to call this proxy.
# The github.io site and a few localhost ports are allowed by default.
# Example:
# ALLOWED_ORIGINS=https://your-custom-domain.com,https://staging.example.com
