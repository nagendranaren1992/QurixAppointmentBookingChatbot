# =================================================================
# Copy this file to `.env` (which is git-ignored) and fill in real
# values. Expo SDK 49+ auto-loads .env files at build time and
# injects any variables prefixed with `EXPO_PUBLIC_` into the bundle.
# =================================================================

# OpenAI API key — used by the conversational agent.
# Get one at https://platform.openai.com/api-keys
#
# WARNING: anything prefixed with EXPO_PUBLIC_ is shipped to the
# client. This is fine for local dev, but for production you MUST
# put a thin backend proxy in front of the OpenAI API so the key
# is never exposed in the browser/app bundle.
EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-key-here

# Optional override — defaults to "gpt-4o" if unset.
# EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini
