# =================================================================
# Copy this file to `.env` (which is git-ignored) and fill in real
# values. Expo SDK 49+ auto-loads .env files at build time and
# injects any variables prefixed with `EXPO_PUBLIC_` into the bundle.
# =================================================================

# -----------------------------------------------------------------
# RECOMMENDED for any deploy that anyone outside your machine can hit:
# point the chatbot at a backend proxy that holds the real OpenAI key.
# A ready-to-deploy Vercel function lives in ./server/ — see its
# README.md for the deploy steps.
# -----------------------------------------------------------------
EXPO_PUBLIC_LLM_PROXY_URL=https://your-proxy.vercel.app/api/chat

# -----------------------------------------------------------------
# LOCAL DEV ONLY — direct OpenAI access, no proxy.
# Anything prefixed with EXPO_PUBLIC_ is bundled into the client, so
# DO NOT use this mode for any public/team-shared build. OpenAI's
# automated secret scanner watches public URLs and will revoke the
# key within minutes if it ends up in a public JS bundle.
# -----------------------------------------------------------------
# EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-key-here

# Optional override — defaults to "gpt-4o" if unset.
# EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini
